@* ============================================================
   Views/History/Index.cshtml
   ============================================================ *@
@using Paralogamadha.Core.Models
@{
    ViewBag.Title = "Our History";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var content  = ViewBag.Content  as IEnumerable<HistoryContent>  ?? Enumerable.Empty<HistoryContent>();
    var timeline = ViewBag.Timeline as IEnumerable<HistoryTimeline> ?? Enumerable.Empty<HistoryTimeline>();
}

<section class="mass-timing-hero text-white">
    <div class="container-fluid px-lg-5">
        <div class="pbl-breadcrumb"><a href="/@ViewBag.CurrentLang/home">Home</a><span class="separator">/</span><span class="current">History</span></div>
        <div class="mt-3" data-aos="fade-up">
            <div class="eyebrow mb-2" style="color:var(--gold-light);font-size:.78rem;letter-spacing:.15em;font-weight:700;text-transform:uppercase">Our Heritage</div>
            <h1 class="display-5 fw-bold">History of the Basilica</h1>
            <p style="opacity:.8">Centuries of faith, devotion and community at Kamanayakkanpatti.</p>
        </div>
    </div>
</section>

@* Rich-text content sections *@
@if (content.Any()) {
<section class="section-gap">
    <div class="container-fluid px-lg-5">
        @foreach (var c in content) {
        <div class="row justify-content-center mb-5" data-aos="fade-up">
            <div class="col-lg-9">
                <h3 class="text-navy mb-4">@c.Title</h3>
                <div class="history-prose">@Html.Raw(c.BodyHtml)</div>
            </div>
        </div>
        }
    </div>
</section>
}

@* Timeline *@
@if (timeline.Any()) {
<section class="section-gap" style="background:var(--sky)">
    <div class="container-fluid px-lg-5">
        <div class="section-heading" data-aos="fade-up">
            <div class="eyebrow">Milestones</div>
            <h2>Timeline</h2>
            <div class="divider"></div>
        </div>

        <div class="history-timeline">
            @{ int idx = 0; }
            @foreach (var t in timeline) {
            <div class="timeline-item" data-aos="@(idx % 2 == 0 ? "fade-right" : "fade-left")">
                <div class="timeline-year">
                    <div class="timeline-year-badge">@t.Year</div>
                </div>
                <div class="timeline-content">
                    <h4>@t.Title</h4>
                    @if (!string.IsNullOrEmpty(t.Description)) {
                        <p>@t.Description</p>
                    }
                    @if (!string.IsNullOrEmpty(t.ImageUrl)) {
                        <img src="@t.ImageUrl" alt="@t.Title" loading="lazy" />
                    }
                </div>
            </div>
            idx++;
            }
        </div>
    </div>
</section>
}

@section Scripts {
<style>
.history-prose {
    font-size:1.05rem; line-height:1.85; color:var(--text);
}
.history-prose h2, .history-prose h3 { color:var(--navy); margin-top:2rem; margin-bottom:1rem; }
.history-prose p   { margin-bottom:1.2rem; }
.history-prose img { max-width:100%; border-radius:12px; margin:1.5rem 0; box-shadow:var(--shadow-card); }
.history-prose blockquote {
    border-left:4px solid var(--gold); background:var(--gold-pale);
    padding:16px 20px; border-radius:0 8px 8px 0; margin:1.5rem 0;
    font-style:italic; color:var(--muted);
}
</style>
}


@* ============================================================
   Views/Gallery/Index.cshtml  (Public)
   ============================================================ *@
@*
@using Paralogamadha.Core.Models
@{
    ViewBag.Title = "Photo Gallery";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var albums     = Model as IEnumerable<GalleryAlbum> ?? Enumerable.Empty<GalleryAlbum>();
    var categories = ViewBag.Categories as IEnumerable<GalleryCategory>;
}

<section class="mass-timing-hero text-white">
    <div class="container-fluid px-lg-5">
        <div class="pbl-breadcrumb"><a href="/@ViewBag.CurrentLang/home">Home</a><span class="separator">/</span><span class="current">Gallery</span></div>
        <div class="mt-3"><h1 class="display-5 fw-bold">Photo Gallery</h1></div>
    </div>
</section>

<section class="section-gap" style="background:var(--sky)">
    <div class="container-fluid px-lg-5">
        <div class="gallery-filter-bar mb-4">
            <button class="filter-btn active" data-filter="all">All Events</button>
            @if (categories != null) {
                foreach (var cat in categories) {
                    <button class="filter-btn" data-filter="@cat.CategoryId">@cat.CategoryName</button>
                }
            }
        </div>
        <div class="row g-4">
            @foreach (var album in albums) {
            <div class="col-md-6 col-lg-4" data-category="@album.CategoryId" data-aos="fade-up">
                <a href="/@ViewBag.CurrentLang/gallery/@album.AlbumId" class="text-decoration-none">
                    <div class="album-card">
                        <div class="album-cover" style="background-image:url('@(album.CoverImageUrl ?? "/Content/images/gallery-placeholder.jpg")')">
                            <span class="album-photo-count"><i class='bx bx-images me-1'></i>@album.PhotoCount</span>
                        </div>
                        <div class="album-body">
                            @if (album.EventDate.HasValue) { <div class="album-date">@album.EventDate.Value.ToString("dd MMM yyyy")</div> }
                            <div class="album-name">@album.AlbumName</div>
                            @if (!string.IsNullOrEmpty(album.CategoryName)) {
                                <span class="mass-lang-badge mt-1">@album.CategoryName</span>
                            }
                        </div>
                    </div>
                </a>
            </div>
            }
        </div>
    </div>
</section>
*@

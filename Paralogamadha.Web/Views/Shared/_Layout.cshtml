@* ============================================================
   Paralogamadha.Web / Views / Shared / _Layout.cshtml
   Main public layout — Bootstrap 5 + glassmorphism
   ============================================================ *@
<!DOCTYPE html>
<html lang="@ViewBag.CurrentLang" dir="ltr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />

    @* ── SEO Meta ── *@
    <title>@ViewBag.MetaTitle</title>
    <meta name="description" content="@ViewBag.MetaDescription" />
    <meta property="og:title"       content="@(ViewBag.OGTitle ?? ViewBag.MetaTitle)" />
    <meta property="og:description" content="@(ViewBag.OGDescription ?? ViewBag.MetaDescription)" />
    <meta property="og:image"       content="@ViewBag.OGImageUrl" />
    <meta property="og:type"        content="website" />
    <meta property="og:url" content="@(Request.Url != null ? Request.Url.AbsoluteUri : "")" />
    <meta name="twitter:card"       content="summary_large_image" />
    <link rel="canonical" href="@(ViewBag.CanonicalUrl ?? (Request.Url != null ? Request.Url.AbsoluteUri : ""))" />

    @if (ViewBag.SchemaJson != null) {
        <script type="application/ld+json">@Html.Raw(ViewBag.SchemaJson)</script>
    }

    @* ── Fonts ── *@
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,600;0,700;1,500&display=swap" rel="stylesheet" />

    @* ── Icons ── *@
    <link href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css" rel="stylesheet" />

    @* ── Bootstrap 5 ── *@
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    @* ── AOS — scroll animations ── *@
    <link href="https://unpkg.com/aos@2.3.4/dist/aos.css" rel="stylesheet" />

    @* ── Swiper — sliders ── *@
    <link href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" rel="stylesheet" />

    @* ── GLightbox ── *@
    <link href="https://cdn.jsdelivr.net/npm/glightbox@3.3.0/dist/css/glightbox.min.css" rel="stylesheet" />

    @* ── Site CSS ── *@
    @Styles.Render("~/bundles/css/site")
</head>
<body>

    @* ══ NAVBAR ══════════════════════════════════════════════ *@
    <nav class="navbar navbar-expand-lg pbl-navbar sticky-top" id="siteNavbar">
        <div class="container-fluid px-lg-5">
            @* Logo *@
            <a class="navbar-brand pbl-brand" href="/@ViewBag.CurrentLang/home">
                <div class="brand-icon">✝</div>
                <div class="brand-text">
                    <span class="brand-title">Paralogamadha</span>
                    <span class="brand-sub">Basilica</span>
                </div>
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
                <i class='bx bx-menu'></i>
            </button>

            <div class="collapse navbar-collapse" id="navbarContent">
                <ul class="navbar-nav me-auto ms-lg-4">
                    <li class="nav-item"><a class="nav-link" href="/@ViewBag.CurrentLang/home">Home</a></li>
                    <li class="nav-item"><a class="nav-link" href="/@ViewBag.CurrentLang/masstiming">Mass Timing</a></li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">Daily</a>
                        <ul class="dropdown-menu pbl-dropdown">
                            <li><a class="dropdown-item" href="/@ViewBag.CurrentLang/daily/feast"><i class='bx bx-sun me-2'></i>Feast of the Day</a></li>
                            <li><a class="dropdown-item" href="/@ViewBag.CurrentLang/daily/reading"><i class='bx bx-book-open me-2'></i>Reading of the Day</a></li>
                            <li><a class="dropdown-item" href="/@ViewBag.CurrentLang/daily/thought"><i class='bx bx-bulb me-2'></i>Thought of the Day</a></li>
                        </ul>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">Media</a>
                        <ul class="dropdown-menu pbl-dropdown">
                            <li><a class="dropdown-item" href="/@ViewBag.CurrentLang/gallery"><i class='bx bx-images me-2'></i>Photo Gallery</a></li>
                            <li><a class="dropdown-item" href="/@ViewBag.CurrentLang/songs"><i class='bx bx-music me-2'></i>Songs</a></li>
                            <li><a class="dropdown-item" href="/@ViewBag.CurrentLang/videos"><i class='bx bx-video me-2'></i>Videos</a></li>
                            <li><a class="dropdown-item" href="/@ViewBag.CurrentLang/virtual-tour"><i class='bx bx-camera me-2'></i>Virtual Tour</a></li>
                            <li><a class="dropdown-item" href="/@ViewBag.CurrentLang/live-tv"><i class='bx bx-tv me-2'></i>Live TV</a></li>
                        </ul>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">About</a>
                        <ul class="dropdown-menu pbl-dropdown">
                            <li><a class="dropdown-item" href="/@ViewBag.CurrentLang/history"><i class='bx bx-time-five me-2'></i>History</a></li>
                            <li><a class="dropdown-item" href="/@ViewBag.CurrentLang/priests"><i class='bx bx-user me-2'></i>Parish Priests</a></li>
                        </ul>
                    </li>
                    <li class="nav-item"><a class="nav-link" href="/@ViewBag.CurrentLang/testimonials">Testimonials</a></li>
                    <li class="nav-item"><a class="nav-link" href="/@ViewBag.CurrentLang/prayer">Prayer</a></li>
                    <li class="nav-item"><a class="nav-link" href="/@ViewBag.CurrentLang/roombooking">Book a Room</a></li>
                </ul>

                <div class="navbar-actions d-flex align-items-center gap-3">
                    @* Language Switcher *@
                    @Html.Partial("_LanguageSwitcher")

                    @* Donate CTA *@
                    <a href="/@ViewBag.CurrentLang/donation" class="btn btn-pbl-gold btn-sm px-3">
                        <i class='bx bx-donate-heart me-1'></i>Donate
                    </a>
                </div>
            </div>
        </div>
    </nav>

    @* ══ FLASH MESSAGES ══════════════════════════════════════ *@
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show m-0 rounded-0" role="alert">
            <i class='bx bx-check-circle me-2'></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @* ══ MAIN CONTENT ════════════════════════════════════════ *@
    @RenderBody()

    @* ══ FOOTER ══════════════════════════════════════════════ *@
    <footer class="pbl-footer">
        <div class="footer-top">
            <div class="container-fluid px-lg-5">
                <div class="row g-4">
                    <div class="col-lg-4">
                        <div class="footer-brand">
                            <div class="footer-cross">✝</div>
                            <h5 class="mt-2">Paralogamadha Basilica</h5>
                            <p class="footer-tagline">Basilica of Our Lady of Assumption<br />Kamanayakkanpatti</p>
                        </div>
                        <div class="footer-social mt-3">
                            @if (ViewBag.FacebookUrl != null && !string.IsNullOrEmpty(ViewBag.FacebookUrl.ToString()))
                            {
                                <a href="@ViewBag.FacebookUrl" target="_blank" rel="noopener" class="social-icon"><i class='bx bxl-facebook'></i></a>
                            }
                            @if (ViewBag.YoutubeUrl != null && !string.IsNullOrEmpty(ViewBag.YoutubeUrl.ToString()))
                            {
                                <a href="@ViewBag.YoutubeUrl" target="_blank" rel="noopener" class="social-icon"><i class='bx bxl-youtube'></i></a>
                            }
                            @if (ViewBag.InstagramUrl != null && !string.IsNullOrEmpty(ViewBag.InstagramUrl.ToString()))
                            {
                                <a href="@ViewBag.InstagramUrl" target="_blank" rel="noopener" class="social-icon"><i class='bx bxl-instagram'></i></a>
                            }
                        </div>
                    </div>

                    <div class="col-lg-2 col-sm-6">
                        <h6 class="footer-heading">Quick Links</h6>
                        <ul class="footer-links">
                            @foreach (var link in (IEnumerable<Paralogamadha.Core.Models.QuickLink>)ViewBag.QuickLinks)
                            {
                                <li><a href="@link.Url"><i class="@link.IconClass me-1"></i>@link.Title</a></li>
                            }
                        </ul>
                    </div>

                    <div class="col-lg-3 col-sm-6">
                        <h6 class="footer-heading">Contact</h6>
                        <ul class="footer-contact">
                            <li><i class='bx bx-map'></i> @ViewBag.SiteAddress</li>
                            <li><i class='bx bx-phone'></i> @ViewBag.SitePhone</li>
                            <li><i class='bx bx-envelope'></i> @ViewBag.SiteEmail</li>
                        </ul>
                    </div>

                    <div class="col-lg-3 col-sm-12">
                        <h6 class="footer-heading">Today at the Basilica</h6>
                        @{
                            var today = DateTime.Today;
                        }
                        <p class="footer-date">@today.ToString("dddd, MMMM dd")</p>
                        <a href="/@ViewBag.CurrentLang/daily/feast" class="footer-daily-link">
                            <i class='bx bx-sun me-1'></i>Feast of the Day
                        </a><br />
                        <a href="/@ViewBag.CurrentLang/daily/reading" class="footer-daily-link">
                            <i class='bx bx-book-open me-1'></i>Today's Readings
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="footer-bottom">
            <div class="container-fluid px-lg-5">
                <div class="row align-items-center">
                    <div class="col-md-6 text-center text-md-start">
                        <small>&copy; @DateTime.Now.Year Paralogamadha Basilica. All rights reserved.</small>
                    </div>
                    <div class="col-md-6 text-center text-md-end">
                        <small>
                            <a href="/sitemap.xml" class="footer-util-link">Sitemap</a>
                            &nbsp;·&nbsp;
                            <a href="/@ViewBag.CurrentLang/privacy" class="footer-util-link">Privacy</a>
                        </small>
                    </div>
                </div>
            </div>
        </div>
    </footer>

    @* ══ SCRIPTS ══════════════════════════════════════════════ *@
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
    <script src="https://unpkg.com/aos@2.3.4/dist/aos.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/glightbox@3.3.0/dist/js/glightbox.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/countup.js/2.8.0/countUp.umd.js"></script>
    <script src="~/Content/js/app.js"></script>
    @*@Scripts.Render("~/bundles/js/site")*@
    @RenderSection("Scripts", required: false)

    <script>
        AOS.init({ duration: 700, once: true, offset: 60 });
    </script>
</body>
</html>

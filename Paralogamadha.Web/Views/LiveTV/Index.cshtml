@* ============================================================
   Views/LiveTV/Index.cshtml
   ============================================================ *@
@using Paralogamadha.Core.Models
@{
    ViewBag.Title = "Live TV";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var channels = Model as IEnumerable<LiveTVChannel> ?? Enumerable.Empty<LiveTVChannel>();
    var active   = channels.FirstOrDefault(c => c.IsLive) ?? channels.FirstOrDefault();
}

<section class="mass-timing-hero text-white" style="padding-bottom:40px">
    <div class="container-fluid px-lg-5">
        <div class="pbl-breadcrumb"><a href="/@ViewBag.CurrentLang/home">Home</a><span class="separator">/</span><span class="current">Live TV</span></div>
        <div class="d-flex align-items-center gap-3 mt-3" data-aos="fade-up">
            <h1 class="display-5 fw-bold mb-0">Live TV</h1>
            @if (active != null && active.IsLive) {
                <span class="live-badge">LIVE</span>
            }
        </div>
        <p style="opacity:.8;margin-top:8px">Watch live Mass, prayers and parish events online.</p>
    </div>
</section>

<section class="section-gap-sm" style="background:#0a0f1e">
    <div class="container-fluid px-lg-5">
        @if (active != null) {
        <div class="livetv-embed-wrap" data-aos="fade-up">
            @if (active.EmbedType == "YouTube") {
                var ytId = System.Text.RegularExpressions.Regex.Match(active.EmbedUrl, @"(?:v=|youtu\.be/)([^&\s]{11})").Groups[1].Value;
                if (string.IsNullOrEmpty(ytId)) ytId = active.EmbedUrl;
                <iframe src="https://www.youtube.com/embed/@ytId?autoplay=0&rel=0"
                        allowfullscreen allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                        title="@active.ChannelName"></iframe>
            } else {
                <iframe src="@active.EmbedUrl" allowfullscreen title="@active.ChannelName"></iframe>
            }
        </div>
        } else {
            <div style="background:rgba(255,255,255,.05);border-radius:16px;aspect-ratio:16/9;display:flex;flex-direction:column;align-items:center;justify-content:center;color:rgba(255,255,255,.4)">
                <i class='bx bx-tv' style="font-size:3.5rem;margin-bottom:12px"></i>
                <p>Live stream will be available during Mass and special events.</p>
            </div>
        }

        @* Channel list *@
        @if (channels.Count() > 1) {
        <div class="d-flex gap-3 mt-4 flex-wrap" data-aos="fade-up">
            @foreach (var ch in channels) {
                <a href="?channel=@ch.ChannelId" class="pbl-card d-flex align-items-center gap-3 p-3 text-decoration-none @(ch.ChannelId == active?.ChannelId ? "" : "")"
                   style="background:rgba(255,255,255,.07);border-color:rgba(255,255,255,.1);color:#fff;min-width:180px">
                    @if (ch.IsLive) { <span class="live-badge">LIVE</span> }
                    else { <i class='bx bx-tv' style="font-size:1.3rem;color:rgba(255,255,255,.5)"></i> }
                    <span style="font-size:.9rem;font-weight:600">@ch.ChannelName</span>
                </a>
            }
        </div>
        }
    </div>
</section>

<section class="section-gap" style="background:var(--sky)">
    <div class="container-fluid px-lg-5">
        <div class="row g-4 align-items-center">
            <div class="col-md-8" data-aos="fade-right">
                <div class="eyebrow mb-2">Watch &amp; Pray</div>
                <h3 class="text-navy">Can't make it to Mass?</h3>
                <p class="text-muted">Join us online — our live stream brings the Mass right to your home. Share with family and friends.</p>
            </div>
            <div class="col-md-4 text-md-end" data-aos="fade-left">
                <a href="/@ViewBag.CurrentLang/masstiming" class="btn-pbl-navy">
                    <i class='bx bx-time me-2'></i>Mass Schedule
                </a>
            </div>
        </div>
    </div>
</section>

@* ============================================================
   Views/Seo/Sitemap.cshtml — sitemap.xml
   ============================================================ *@
@{
    Layout = null;
    Response.ContentType = "application/xml";
    var data    = Model as Tuple<IEnumerable<Paralogamadha.Core.Models.Priest>, IEnumerable<Paralogamadha.Core.Models.GalleryAlbum>>;
    var priests = data?.Item1;
    var albums  = data?.Item2;
    var baseUrl = $"{Request.Url?.Scheme}://{Request.Url?.Host}";
    string[] langs = { "en", "ta", "hi" };
    string now = DateTime.UtcNow.ToString("yyyy-MM-ddTHH:mm:ssZ");
}<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
        xmlns:xhtml="http://www.w3.org/1999/xhtml">

    @* Static pages — all languages *@
    @foreach (var lang in langs) {
    <url>
        <loc>@baseUrl/@lang/home</loc>
        <lastmod>@now</lastmod>
        <changefreq>daily</changefreq>
        <priority>1.0</priority>
        @foreach (var altLang in langs) {
        <xhtml:link rel="alternate" hreflang="@altLang" href="@baseUrl/@altLang/home" />
        }
    </url>
    <url><loc>@baseUrl/@lang/masstiming</loc><lastmod>@now</lastmod><changefreq>weekly</changefreq><priority>0.9</priority></url>
    <url><loc>@baseUrl/@lang/prayer</loc><lastmod>@now</lastmod><changefreq>monthly</changefreq><priority>0.7</priority></url>
    <url><loc>@baseUrl/@lang/testimonials</loc><lastmod>@now</lastmod><changefreq>weekly</changefreq><priority>0.6</priority></url>
    <url><loc>@baseUrl/@lang/daily/feast</loc><lastmod>@now</lastmod><changefreq>daily</changefreq><priority>0.8</priority></url>
    <url><loc>@baseUrl/@lang/daily/reading</loc><lastmod>@now</lastmod><changefreq>daily</changefreq><priority>0.8</priority></url>
    <url><loc>@baseUrl/@lang/daily/thought</loc><lastmod>@now</lastmod><changefreq>daily</changefreq><priority>0.8</priority></url>
    <url><loc>@baseUrl/@lang/gallery</loc><lastmod>@now</lastmod><changefreq>weekly</changefreq><priority>0.7</priority></url>
    <url><loc>@baseUrl/@lang/priests</loc><lastmod>@now</lastmod><changefreq>monthly</changefreq><priority>0.7</priority></url>
    <url><loc>@baseUrl/@lang/history</loc><lastmod>@now</lastmod><changefreq>yearly</changefreq><priority>0.6</priority></url>
    <url><loc>@baseUrl/@lang/donation</loc><lastmod>@now</lastmod><changefreq>monthly</changefreq><priority>0.8</priority></url>
    <url><loc>@baseUrl/@lang/roombooking</loc><lastmod>@now</lastmod><changefreq>monthly</changefreq><priority>0.7</priority></url>
    <url><loc>@baseUrl/@lang/live-tv</loc><lastmod>@now</lastmod><changefreq>weekly</changefreq><priority>0.6</priority></url>
    <url><loc>@baseUrl/@lang/virtual-tour</loc><lastmod>@now</lastmod><changefreq>yearly</changefreq><priority>0.5</priority></url>
    <url><loc>@baseUrl/@lang/songs</loc><lastmod>@now</lastmod><changefreq>monthly</changefreq><priority>0.5</priority></url>
    <url><loc>@baseUrl/@lang/videos</loc><lastmod>@now</lastmod><changefreq>monthly</changefreq><priority>0.5</priority></url>
    }

    @* Dynamic pages — priests *@
    @if (priests != null) {
        foreach (var p in priests) {
    <url>
        <loc>@baseUrl/en/priests#@p.PriestId</loc>
        <lastmod>@now</lastmod>
        <changefreq>yearly</changefreq>
        <priority>0.4</priority>
    </url>
        }
    }

    @* Dynamic pages — gallery albums *@
    @if (albums != null) {
        foreach (var a in albums.Where(x => x.IsPublished)) {
    <url>
        <loc>@baseUrl/en/gallery/@a.AlbumId</loc>
        <lastmod>@now</lastmod>
        <changefreq>yearly</changefreq>
        <priority>0.4</priority>
    </url>
        }
    }
</urlset>

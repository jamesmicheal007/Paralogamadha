@* ============================================================
   Views/Testimonials/Index.cshtml
   ============================================================ *@
@{
    ViewBag.Title = "Testimonials";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var testimonials = Model as IEnumerable<Paralogamadha.Core.Models.Testimonial>;
    var antiForgery  = Html.AntiForgeryToken().ToString();
}

<section class="mass-timing-hero text-white">
    <div class="container-fluid px-lg-5">
        <div class="pbl-breadcrumb"><a href="/@ViewBag.CurrentLang/home">Home</a><span class="separator">/</span><span class="current">Testimonials</span></div>
        <div class="mt-3" data-aos="fade-up">
            <div class="eyebrow mb-2" style="color:var(--gold-light);font-size:.78rem;letter-spacing:.15em;font-weight:700;text-transform:uppercase">Community Stories</div>
            <h1 class="display-5 fw-bold">What Our Parish Says</h1>
        </div>
    </div>
</section>

@* Testimonial Grid *@
<section class="section-gap">
    <div class="container-fluid px-lg-5">
        @if (testimonials != null && testimonials.Any()) {
        <div class="row g-4">
            @foreach (var t in testimonials) {
            <div class="col-md-6 col-lg-4" data-aos="fade-up">
                <div class="testimonial-card">
                    <div class="star-rating">
                        @for (int i = 1; i <= 5; i++) {
                            <i class="bx @(i <= t.Rating ? "bxs-star" : "bx-star")"></i>
                        }
                    </div>
                    <p class="testimonial-text">@t.TestimonialText</p>
                    <div class="testimonial-author">
                        <div class="testimonial-avatar">
                            @if (!string.IsNullOrEmpty(t.PhotoUrl)) {
                                <img src="@t.PhotoUrl" alt="@t.AuthorName" />
                            } else {
                                @t.AuthorName.Substring(0, 1).ToUpper()
                            }
                        </div>
                        <div>
                            <div class="testimonial-name">@t.AuthorName</div>
                            @if (!string.IsNullOrEmpty(t.AuthorLocation)) {
                                <div class="testimonial-location"><i class='bx bx-map-pin me-1'></i>@t.AuthorLocation</div>
                            }
                        </div>
                    </div>
                </div>
            </div>
            }
        </div>
        } else {
            <div class="text-center py-5 text-muted">
                <i class='bx bx-star' style="font-size:3rem;opacity:.3"></i>
                <h5 class="mt-3">No testimonials yet.</h5>
            </div>
        }
    </div>
</section>

@* Submit Testimonial *@
<section class="section-gap" style="background:var(--sky)">
    <div class="container-fluid px-lg-5">
        <div class="row justify-content-center">
            <div class="col-lg-7">
                <div class="pbl-card p-5" data-aos="fade-up">
                    <div class="text-center mb-4">
                        <div class="eyebrow">Share Your Story</div>
                        <h3>Submit a Testimonial</h3>
                        <p class="text-muted">Your testimonial will be reviewed before publishing.</p>
                    </div>

                    <form id="testimonialForm" action="/@ViewBag.CurrentLang/testimonials/submit" method="post" novalidate>
                        @Html.Raw(antiForgery)
                        <div class="row g-3">
                            <div class="col-md-6 form-group">
                                <label class="pbl-label">Your Name *</label>
                                <input type="text" class="pbl-input" name="AuthorName" required placeholder="Full name" />
                            </div>
                            <div class="col-md-6 form-group">
                                <label class="pbl-label">Location</label>
                                <input type="text" class="pbl-input" name="AuthorLocation" placeholder="e.g. Chennai, Tamil Nadu" />
                            </div>
                        </div>

                        @* Star Rating *@
                        <div class="form-group">
                            <label class="pbl-label">Rating *</label>
                            <input type="hidden" id="Rating" name="Rating" value="5" required />
                            <div class="star-rating-widget d-flex gap-2 mt-1">
                                @for (int i = 1; i <= 5; i++) {
                                    <button type="button" class="star-btn filled" data-value="@i"
                                            style="background:none;border:none;font-size:1.8rem;color:var(--gold);cursor:pointer;padding:0;transition:transform .15s">
                                        ★
                                    </button>
                                }
                            </div>
                        </div>

                        <div class="form-group">
                            <label class="pbl-label">Your Testimonial *</label>
                            <textarea class="pbl-input" name="TestimonialText" rows="5" required
                                      placeholder="Share your experience with our parish community…"></textarea>
                        </div>

                        <button type="submit" class="btn-pbl-navy ripple w-100" style="padding:13px">
                            <i class='bx bx-send me-2'></i>Submit Testimonial
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
<script>
// Star rating hover states
document.querySelectorAll('.star-btn').forEach((star, idx, stars) => {
    star.addEventListener('mouseenter', () => stars.forEach((s, i) => s.style.color = i <= idx ? 'var(--gold)' : '#cbd5e1'));
    star.addEventListener('mouseleave', () => {
        const val = parseInt(document.getElementById('Rating').value);
        stars.forEach((s, i) => s.style.color = i < val ? 'var(--gold)' : '#cbd5e1');
    });
    star.addEventListener('click', () => {
        document.getElementById('Rating').value = idx + 1;
        stars.forEach((s, i) => s.style.color = i <= idx ? 'var(--gold)' : '#cbd5e1');
    });
});
</script>
}

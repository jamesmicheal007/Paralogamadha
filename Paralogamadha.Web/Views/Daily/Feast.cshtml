@* ============================================================
   Views/Daily/Feast.cshtml
   ============================================================ *@
@{
    ViewBag.Title = "Feast of the Day";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var feast = Model as Paralogamadha.Core.Models.FeastOfDay;
    var today = DateTime.Today;
}
<section class="mass-timing-hero text-white">
    <div class="container-fluid px-lg-5">
        <div class="pbl-breadcrumb"><a href="/@ViewBag.CurrentLang/home">Home</a><span class="separator">/</span><span class="current">Feast of the Day</span></div>
        <div class="mt-3" data-aos="fade-up">
            <div class="eyebrow mb-2" style="color:var(--gold-light);font-size:.78rem;letter-spacing:.15em;font-weight:700;text-transform:uppercase">Liturgical Calendar</div>
            <h1 class="display-5 fw-bold">Feast of the Day</h1>
            <p style="opacity:.7">@today.ToString("dddd, MMMM dd, yyyy")</p>
        </div>
    </div>
</section>

<section class="section-gap">
    <div class="container-fluid px-lg-5">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                @if (feast != null) {
                <div class="pbl-card overflow-hidden" data-aos="fade-up">
                    @if (!string.IsNullOrEmpty(feast.ImageUrl)) {
                        <div class="zoom-wrap" style="height:320px;overflow:hidden">
                            <img src="@feast.ImageUrl" alt="@feast.SaintName"
                                 style="width:100%;height:100%;object-fit:cover" />
                        </div>
                    } else {
                        <div style="height:160px;background:linear-gradient(135deg,var(--navy),var(--navy-light));display:flex;align-items:center;justify-content:center;font-size:5rem;color:rgba(255,255,255,.15)">✝</div>
                    }
                    <div class="p-5">
                        <div class="eyebrow mb-3">Today's Feast</div>
                        <h2 class="mb-4">@feast.SaintName</h2>
                        @if (!string.IsNullOrEmpty(feast.Description)) {
                            <div style="font-size:1.05rem;line-height:1.85;color:var(--text)">@feast.Description</div>
                        }
                    </div>
                </div>
                } else {
                <div class="text-center py-5" data-aos="fade-up">
                    <div style="font-size:4rem;opacity:.2;margin-bottom:16px">✝</div>
                    <h4 class="text-navy mb-2">No feast information for today</h4>
                    <p class="text-muted">Please check back later or contact the parish office.</p>
                </div>
                }
            </div>
            <div class="col-lg-4 mt-4 mt-lg-0">
                <div class="pbl-card p-4 mb-3" data-aos="fade-left">
                    <h6 class="text-navy mb-3"><i class='bx bx-book-open me-2 text-gold'></i>Today's Reading</h6>
                    <a href="/@ViewBag.CurrentLang/daily/reading" class="btn-pbl-outline d-block text-center">View Readings</a>
                </div>
                <div class="pbl-card p-4" data-aos="fade-left" data-aos-delay="100">
                    <h6 class="text-navy mb-3"><i class='bx bx-bulb me-2 text-gold'></i>Thought of the Day</h6>
                    <a href="/@ViewBag.CurrentLang/daily/thought" class="btn-pbl-outline d-block text-center">View Thought</a>
                </div>
            </div>
        </div>
    </div>
</section>

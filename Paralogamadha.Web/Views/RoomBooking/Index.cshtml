@* ============================================================
   Views/RoomBooking/Index.cshtml — Public Room Booking
   ============================================================ *@
@{
    ViewBag.Title = "Room Booking";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var rooms = ViewBag.Rooms as IEnumerable<Paralogamadha.Core.Models.Room>;
    var antiForgery = Html.AntiForgeryToken().ToString();
}

<section class="mass-timing-hero text-white">
    <div class="container-fluid px-lg-5">
        <div class="pbl-breadcrumb"><a href="/@ViewBag.CurrentLang/home">Home</a><span class="separator">/</span><span class="current">Room Booking</span></div>
        <div class="mt-3" data-aos="fade-up">
            <div class="eyebrow mb-2" style="color:var(--gold-light);font-size:.78rem;letter-spacing:.15em;font-weight:700;text-transform:uppercase">Parish Facilities</div>
            <h1 class="display-5 fw-bold">Book a Room or Hall</h1>
            <p style="opacity:.8">Reserve our parish facilities for your events and gatherings.</p>
        </div>
    </div>
</section>

<section class="section-gap" style="background:var(--sky)">
    <div class="container-fluid px-lg-5">
        <div class="row g-4">

            @* Room selection *@
            <div class="col-12">
                <div class="section-heading text-start" style="margin-bottom:24px" data-aos="fade-up">
                    <div class="eyebrow">Step 1</div>
                    <h3>Choose a Room</h3>
                </div>
                <div class="row g-3" data-aos="fade-up">
                    @if (rooms != null) {
                        foreach (var room in rooms) {
                        <div class="col-md-6 col-lg-4">
                            <div class="room-card pbl-card" data-room="@room.RoomId" tabindex="0"
                                 role="button" aria-label="Select @room.RoomName">
                                <div class="room-img" style="@(!string.IsNullOrEmpty(room.ImageUrl) ? $"background-image:url('{room.ImageUrl}')" : "background:var(--sky)")">
                                    @if (string.IsNullOrEmpty(room.ImageUrl)) {
                                        <div style="height:100%;display:flex;align-items:center;justify-content:center;font-size:3rem;color:#cbd5e1">
                                            <i class='bx bx-building'></i>
                                        </div>
                                    }
                                </div>
                                <div class="room-body">
                                    <div class="room-name">@room.RoomName</div>
                                    <div class="room-meta">
                                        <span><i class='bx bx-group'></i>Up to @room.Capacity</span>
                                        @if (room.HourlyRate > 0) {
                                            <span><i class='bx bx-rupee'></i>₹@room.HourlyRate/hr</span>
                                        } else {
                                            <span><i class='bx bx-gift'></i>Free</span>
                                        }
                                    </div>
                                    @if (!string.IsNullOrEmpty(room.Description)) {
                                        <p class="mt-2 mb-0" style="font-size:.82rem;color:var(--muted)">@room.Description</p>
                                    }
                                </div>
                            </div>
                        </div>
                        }
                    }
                </div>
            </div>

            @* Booking Form *@
            <div class="col-lg-8 col-xl-7 mx-auto">
                <div id="bookingSuccess" style="display:none" class="form-success-state pbl-card p-5">
                    <div class="success-icon"><i class='bx bx-calendar-check'></i></div>
                    <h4 class="text-navy mb-2">Booking Request Submitted!</h4>
                    <p class="text-muted mb-2">Your reference number: <strong id="bookingSuccessRef" class="text-navy"></strong></p>
                    <p class="text-muted mb-4">You will receive a confirmation email once your booking is reviewed and approved.</p>
                    <a href="/@ViewBag.CurrentLang/home" class="btn-pbl-navy">Return Home</a>
                </div>

                <form id="roomBookingForm" action="/@ViewBag.CurrentLang/roombooking/book" method="post" novalidate>
                    @Html.Raw(antiForgery)
                    <input type="hidden" id="RoomId" name="RoomId" required />

                    <div class="pbl-card p-4" data-aos="fade-up">
                        <div class="section-heading text-start" style="margin-bottom:20px">
                            <div class="eyebrow">Step 2</div>
                            <h3>Date & Time</h3>
                        </div>

                        <div class="row g-3">
                            <div class="col-md-6 form-group">
                                <label class="pbl-label" for="StartDateTime">Start Date & Time *</label>
                                <input type="datetime-local" class="pbl-input" id="StartDateTime" name="StartDateTime" required
                                       min="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" />
                            </div>
                            <div class="col-md-6 form-group">
                                <label class="pbl-label" for="EndDateTime">End Date & Time *</label>
                                <input type="datetime-local" class="pbl-input" id="EndDateTime" name="EndDateTime" required
                                       min="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" />
                            </div>
                        </div>

                        <div id="availabilityMsg" class="mt-2" style="font-size:.88rem;min-height:20px"></div>

                        <hr class="my-4" />

                        <div class="section-heading text-start" style="margin-bottom:20px">
                            <div class="eyebrow">Step 3</div>
                            <h3>Your Details</h3>
                        </div>

                        <div class="row g-3">
                            <div class="col-md-6 form-group">
                                <label class="pbl-label" for="BookedByName">Full Name *</label>
                                <input type="text" class="pbl-input" id="BookedByName" name="BookedByName" required
                                       placeholder="Your name" autocomplete="name" />
                            </div>
                            <div class="col-md-6 form-group">
                                <label class="pbl-label" for="Email">Email *</label>
                                <input type="email" class="pbl-input" id="Email" name="Email" required
                                       placeholder="you@example.com" autocomplete="email" />
                            </div>
                            <div class="col-md-6 form-group">
                                <label class="pbl-label" for="Phone">Phone Number *</label>
                                <input type="tel" class="pbl-input" id="Phone" name="Phone" required
                                       placeholder="+91 XXXXX XXXXX" autocomplete="tel" />
                            </div>
                            <div class="col-12 form-group">
                                <label class="pbl-label" for="Purpose">Purpose of Booking *</label>
                                <textarea class="pbl-input" id="Purpose" name="Purpose" rows="3" required
                                          placeholder="Describe the purpose of your booking…"></textarea>
                            </div>
                        </div>

                        <div class="p-3 rounded-2 mb-4 mt-2" style="background:var(--sky);font-size:.85rem;color:var(--muted)">
                            <i class='bx bx-info-circle me-2 text-navy'></i>
                            Bookings are subject to approval by the parish office. You will be notified via email.
                        </div>

                        <button type="submit" class="btn-pbl-navy ripple w-100" style="padding:14px">
                            <i class='bx bx-calendar-plus me-2'></i>Submit Booking Request
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>

@* ============================================================
    Views/Home/Index.cshtml  — Home Page
    ============================================================ *@
@model Paralogamadha.Web.Models.HomeViewModel
@using Paralogamadha.Core.Models
@{
    ViewBag.Title = "Home";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var model = Model as dynamic;
    var today = DateTime.Today;
    var todayDay = (int)today.DayOfWeek;
}

@* ── Announcement Ticker ─────────────────────────────────── *@
@if (Model.Announcements != null)
{
    var anns = model.Announcements as IEnumerable<Paralogamadha.Core.Models.Announcement>;
    if (anns.Any())
    {
        <div class="announcement-bar">
            <div class="d-flex align-items-center gap-3 px-lg-5 px-3">
                <span class="announcement-label"><i class='bx bx-bell me-1'></i>Notice</span>
                <div class="ticker-wrap">
                    <div class="ticker-items">
                        @foreach (var ann in anns)
                        {
                            <span class="ticker-item"><i class='bx bx-chevron-right'></i>@ann.Title</span>
                        }
                        @* Duplicate for seamless loop *@
                        @foreach (var ann in anns)
                        {
                            <span class="ticker-item"><i class='bx bx-chevron-right'></i>@ann.Title</span>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
}

@* ── Hero Slider ─────────────────────────────────────────── *@
<section class="pbl-hero">
    <div class="swiper hero-swiper">
        <div class="swiper-wrapper">
            @{
                var slides = model.HeroSlides as IEnumerable<Paralogamadha.Core.Models.HeroSlide>;
                if (slides == null || !slides.Any())
                {
                    <div class="swiper-slide">
                        <div class="hero-slide" style="background-image:url('/Content/images/hero-default.jpg')">
                            <div class="hero-content">
                                <div class="hero-text">
                                    <div class="hero-eyebrow anim-fade-up">Basilica of Our Lady of Assumption</div>
                                    <h1 class="hero-title anim-fade-up anim-delay-1">Welcome to Paralogamadha Basilica</h1>
                                    <p class="hero-subtitle anim-fade-up anim-delay-2">Kamanayakkanpatti — A Sacred Place of Grace</p>
                                    <div class="hero-actions anim-fade-up anim-delay-3">
                                        <a href="/@ViewBag.CurrentLang/masstiming" class="btn-pbl-gold ripple">View Mass Timings</a>
                                        <a href="/@ViewBag.CurrentLang/prayer" class="btn-pbl-outline text-white border-white">Prayer Request</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    foreach (var slide in slides)
                    {
                        <div class="swiper-slide">
                            <div class="hero-slide" style="background-image:url('@slide.BackgroundImageUrl')">
                                <div class="hero-content">
                                    <div class="hero-text">
                                        <div class="hero-eyebrow">Basilica of Our Lady of Assumption</div>
                                        <h1 class="hero-title">@slide.Title</h1>
                                        @if (!string.IsNullOrEmpty(slide.SubTitle))
                                        {
                                            <p class="hero-subtitle">@slide.SubTitle</p>
                                        }
                                        @if (!string.IsNullOrEmpty(slide.ButtonText))
                                        {
                                            <div class="hero-actions">
                                                <a href="@slide.ButtonUrl" class="btn-pbl-gold ripple">@slide.ButtonText</a>
                                                <a href="/@ViewBag.CurrentLang/prayer" class="btn-pbl-outline text-white border-white">Prayer Request</a>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
            }
        </div>
        <div class="swiper-button-prev"></div>
        <div class="swiper-button-next"></div>
        <div class="swiper-pagination"></div>
    </div>
    <div class="hero-scroll-indicator">
        <span>Scroll</span>
        <i class='bx bx-chevron-down'></i>
    </div>
</section>

@* ── Daily Strip (Feast / Thought / Reading) ──────────────── *@
<section class="daily-strip">
    <div class="container-fluid px-lg-5">
        <div class="row g-3">
            @* Feast of the Day *@
            <div class="col-md-4" data-aos="fade-up" data-aos-delay="0">
                <a href="/@ViewBag.CurrentLang/daily/feast" class="text-decoration-none">
                    <div class="daily-strip-card">
                        <div class="daily-strip-icon"><i class='bx bx-sun'></i></div>
                        <div class="daily-strip-label">Feast of the Day</div>
                        <div class="daily-strip-title">
                            @{
                                var feast = model.TodayFeast as Paralogamadha.Core.Models.FeastOfDay;
                            }
                            @(feast != null ? feast.SaintName : today.ToString("dddd, MMM d"))
                        </div>
                        <span class="daily-strip-link">Read more <i class='bx bx-right-arrow-alt'></i></span>
                    </div>
                </a>
            </div>

            @* Thought of the Day *@
            <div class="col-md-4" data-aos="fade-up" data-aos-delay="100">
                <a href="/@ViewBag.CurrentLang/daily/thought" class="text-decoration-none">
                    <div class="daily-strip-card">
                        <div class="daily-strip-icon"><i class='bx bx-bulb'></i></div>
                        <div class="daily-strip-label">Thought of the Day</div>
                        <div class="daily-strip-title">
                            @{
                                var thought = model.TodayThought as Paralogamadha.Core.Models.ThoughtOfDay;
                            }
                            @if (thought != null)
                            {
                                <span>"@(thought.Quote.Length > 60 ? thought.Quote.Substring(0, 60) + "…" : thought.Quote)"</span>
                            }
                            else
                            {
                                <span>Daily Inspiration</span>
                            }
                        </div>
                        <span class="daily-strip-link">Read more <i class='bx bx-right-arrow-alt'></i></span>
                    </div>
                </a>
            </div>

            @* Reading of the Day *@
            <div class="col-md-4" data-aos="fade-up" data-aos-delay="200">
                <a href="/@ViewBag.CurrentLang/daily/reading" class="text-decoration-none">
                    <div class="daily-strip-card">
                        <div class="daily-strip-icon"><i class='bx bx-book-open'></i></div>
                        <div class="daily-strip-label">Reading of the Day</div>
                        <div class="daily-strip-title">
                            @{
                                var reading = model.TodayReading as Paralogamadha.Core.Models.ReadingOfDay;
                            }
                            @(reading != null && !string.IsNullOrEmpty(reading.GospelRef) ? reading.GospelRef : "Today's Gospel")
                        </div>
                        <span class="daily-strip-link">Read more <i class='bx bx-right-arrow-alt'></i></span>
                    </div>
                </a>
            </div>
        </div>
    </div>
</section>

@* ── Quick Links ──────────────────────────────────────────── *@
<section class="section-gap-sm bg-white">
    <div class="container-fluid px-lg-5">
        <div class="quick-links-grid" data-aos="fade-up">
            @{
                var links = ViewBag.QuickLinks as IEnumerable<Paralogamadha.Core.Models.QuickLink>;
                if (links != null)
                {
                    foreach (var link in links)
                    {
                        <a href="@link.Url" class="quick-link-item">
                            <i class="@link.IconClass"></i>
                            @link.Title
                        </a>
                    }
                }
            }
        </div>
    </div>
</section>

@* ── Today's Mass Timings ─────────────────────────────────── *@
<section class="section-gap" style="background:var(--sky)">
    <div class="container-fluid px-lg-5">
        <div class="section-heading" data-aos="fade-up">
            <div class="eyebrow">Liturgy</div>
            <h2>Today's Mass Timings</h2>
            <div class="divider"></div>
            <p>@today.ToString("dddd, MMMM dd, yyyy")</p>
        </div>

        @{
            var todayMasses = model.TodayMasses as IEnumerable<Paralogamadha.Core.Models.MassSchedule>;
        }

        @if (todayMasses != null && todayMasses.Any())
        {
            <div class="row g-3 justify-content-center">
                @foreach (var mass in todayMasses)
                {
                    <div class="col-md-4 col-sm-6" data-aos="fade-up">
                        <div class="mass-timing-card">
                            <div class="mass-time-badge">@mass.MassTimeDisplay</div>
                            <div class="mass-details">
                                <h6>@(string.IsNullOrEmpty(mass.Venue) ? "Main Basilica" : mass.Venue)</h6>
                                <span class="mass-lang-badge">@mass.MassLanguage</span>
                                @if (!string.IsNullOrEmpty(mass.Celebrant))
                                {
                                    <div class="mt-1" style="font-size:.8rem;color:var(--muted)">
                                        <i class='bx bx-user me-1'></i>@mass.Celebrant
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-center py-4 text-muted">No masses scheduled for today.</div>
        }

        <div class="text-center mt-4" data-aos="fade-up">
            <a href="/@ViewBag.CurrentLang/masstiming" class="btn-pbl-navy">
                <i class='bx bx-time me-2'></i>Full Mass Schedule
            </a>
        </div>
    </div>
</section>

@* ── Stats Counter ────────────────────────────────────────── *@
<section class="stats-section">
    <div class="container-fluid px-lg-5">
        <div class="row g-4 align-items-center">
            <div class="col-6 col-md-3 stat-item" data-aos="fade-up" data-aos-delay="0">
                <div class="stat-number"><span data-count="400">0</span>+</div>
                <div class="stat-label">Years of Faith</div>
            </div>
            <div class="col-6 col-md-3 stat-item" data-aos="fade-up" data-aos-delay="100">
                <div class="stat-number"><span data-count="5000">0</span>+</div>
                <div class="stat-label">Faithful Families</div>
            </div>
            <div class="col-6 col-md-3 stat-item" data-aos="fade-up" data-aos-delay="200">
                <div class="stat-number"><span data-count="365">0</span></div>
                <div class="stat-label">Days of Prayer</div>
            </div>
            <div class="col-6 col-md-3 stat-item" data-aos="fade-up" data-aos-delay="300">
                <div class="stat-number"><span data-count="12">0</span></div>
                <div class="stat-label">Annual Feasts</div>
            </div>
        </div>
    </div>
</section>

@* ── Testimonials ─────────────────────────────────────────── *@
@{
    var testimonials = model.Testimonials as IEnumerable<Paralogamadha.Core.Models.Testimonial>;
}
@if (testimonials != null && testimonials.Any())
{
    <section class="section-gap">
        <div class="container-fluid px-lg-5">
            <div class="section-heading" data-aos="fade-up">
                <div class="eyebrow">Community</div>
                <h2>What Our Parish Says</h2>
                <div class="divider"></div>
            </div>
            <div class="swiper testimonial-swiper" data-aos="fade-up">
                <div class="swiper-wrapper">
                    @foreach (var t in testimonials)
                    {
                        <div class="swiper-slide">
                            <div class="testimonial-card">
                                <div class="star-rating">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        <i class="bx @(i <= t.Rating ? "bxs-star" : "bx-star")"></i>
                                    }
                                </div>
                                <p class="testimonial-text">@t.TestimonialText</p>
                                <div class="testimonial-author">
                                    <div class="testimonial-avatar">
                                        @if (!string.IsNullOrEmpty(t.PhotoUrl))
                                        {
                                            <img src="@t.PhotoUrl" alt="@t.AuthorName" />
                                        }
                                        else
                                        {
                                            @t.AuthorName.Substring(0, 1).ToUpper()
                                        }
                                    </div>
                                    <div>
                                        <div class="testimonial-name">@t.AuthorName</div>
                                        @if (!string.IsNullOrEmpty(t.AuthorLocation))
                                        {
                                            <div class="testimonial-location"><i class='bx bx-map-pin me-1'></i>@t.AuthorLocation</div>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
                <div class="swiper-pagination mt-4 position-relative"></div>
            </div>
            <div class="text-center mt-4" data-aos="fade-up">
                <a href="/@ViewBag.CurrentLang/testimonials" class="btn-pbl-outline">Share Your Story</a>
            </div>
        </div>
    </section>
}

@* ── Donate CTA ───────────────────────────────────────────── *@
<section class="section-gap" style="background:linear-gradient(135deg,var(--navy) 0%,var(--navy-light) 100%)">
    <div class="container-fluid px-lg-5 text-center text-white">
        <div class="float-cross mb-3" style="font-size:3rem;color:var(--gold-light)">&#10013;</div>
        <h2 class="font-serif text-white mb-3" style="font-size:clamp(1.8rem,4vw,2.8rem)" data-aos="fade-up">
            Support Our Sacred Mission
        </h2>
        <p class="mb-4" style="opacity:.8;max-width:520px;margin:0 auto 28px" data-aos="fade-up" data-aos-delay="100">
            Your generous donation helps maintain this sacred Basilica, support community programs, and spread the faith.
        </p>
        <div class="d-flex gap-3 justify-content-center flex-wrap" data-aos="fade-up" data-aos-delay="200">
            <a href="/@ViewBag.CurrentLang/donation" class="btn-pbl-gold ripple">
                <i class='bx bx-donate-heart me-2'></i>Donate Now
            </a>
            <a href="/@ViewBag.CurrentLang/prayer" class="btn-pbl-outline text-white border-white">
                <i class='bx bx-heart me-2'></i>Prayer Request
            </a>
        </div>
    </div>
</section>

<div class="back-to-top" title="Back to top"><i class='bx bx-up-arrow-alt'></i></div>

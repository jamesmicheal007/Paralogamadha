@* ============================================================
   Views/Gallery/Album.cshtml — Album Photo View with Lightbox
   ============================================================ *@
@using Paralogamadha.Core.Models
@{
    ViewBag.Title = (ViewBag.Album as GalleryAlbum)?.AlbumName ?? "Album";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var album  = ViewBag.Album as GalleryAlbum;
    var photos = Model as IEnumerable<GalleryPhoto> ?? Enumerable.Empty<GalleryPhoto>();
}

<section class="mass-timing-hero text-white" style="padding-bottom:40px">
    <div class="container-fluid px-lg-5">
        <div class="pbl-breadcrumb">
            <a href="/@ViewBag.CurrentLang/home">Home</a><span class="separator">/</span>
            <a href="/@ViewBag.CurrentLang/gallery">Gallery</a><span class="separator">/</span>
            <span class="current">@album?.AlbumName</span>
        </div>
        <div class="mt-3" data-aos="fade-up">
            @if (!string.IsNullOrEmpty(album?.CategoryName)) {
                <div class="eyebrow mb-2" style="color:var(--gold-light);font-size:.78rem;letter-spacing:.15em;font-weight:700;text-transform:uppercase">@album.CategoryName</div>
            }
            <h1 class="display-5 fw-bold">@album?.AlbumName</h1>
            <div class="d-flex gap-3 mt-2" style="opacity:.75;font-size:.88rem">
                @if (album?.EventDate.HasValue == true) {
                    <span><i class='bx bx-calendar me-1'></i>@album.EventDate.Value.ToString("dd MMMM yyyy")</span>
                }
                <span><i class='bx bx-images me-1'></i>@photos.Count() photos</span>
            </div>
        </div>
    </div>
</section>

@if (!string.IsNullOrEmpty(album?.Description)) {
<section class="py-4" style="background:#fff">
    <div class="container-fluid px-lg-5">
        <p class="text-muted" style="font-size:.95rem;max-width:700px">@album.Description</p>
    </div>
</section>
}

<section class="section-gap-sm" style="background:var(--sky)">
    <div class="container-fluid px-lg-5">
        @if (photos.Any()) {
        <div class="row g-2 g-md-3" data-aos="fade-up">
            @{ int idx = 0; }
            @foreach (var photo in photos) {
            <div class="col-6 col-sm-4 col-md-3 col-lg-2">
                <a class="glightbox zoom-wrap d-block"
                   href="@photo.ImageUrl"
                   data-gallery="album-@album?.AlbumId"
                   data-title="@photo.Caption"
                   data-description="@photo.AltText"
                   style="height:160px;display:block;border-radius:8px;overflow:hidden;background:var(--border)">
                    <img src="@(photo.ThumbnailUrl ?? photo.ImageUrl)"
                         alt="@(photo.AltText ?? photo.Caption)"
                         loading="lazy"
                         style="width:100%;height:100%;object-fit:cover;transition:transform .4s ease" />
                </a>
            </div>
            idx++;
            }
        </div>
        } else {
            <div class="text-center py-5 text-muted">
                <i class='bx bx-image' style="font-size:3rem;opacity:.3;display:block;margin-bottom:12px"></i>
                No photos in this album yet.
            </div>
        }

        <div class="text-center mt-5" data-aos="fade-up">
            <a href="/@ViewBag.CurrentLang/gallery" class="btn-pbl-outline">
                <i class='bx bx-arrow-back me-2'></i>Back to All Albums
            </a>
        </div>
    </div>
</section>

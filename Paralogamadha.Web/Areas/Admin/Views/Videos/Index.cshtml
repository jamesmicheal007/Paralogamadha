@* ============================================================
   Areas/Admin/Views/Videos/Index.cshtml
   ============================================================ *@
@using Paralogamadha.Core.Models
@{
    ViewBag.Title = "Videos";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    var videos     = Model as IEnumerable<Video> ?? Enumerable.Empty<Video>();
    var categories = ViewBag.Categories as IEnumerable<VideoCategory>;
}
<div class="admin-breadcrumb">
    <a href="/admin/dashboard">Dashboard</a><span class="sep mx-2">/</span>
    <span class="current">Videos</span>
</div>
<div class="admin-panel">
    <div class="panel-header">
        <div class="panel-title"><i class='bx bx-video'></i>Videos</div>
        <a href="/admin/videosadmin/create" class="btn-admin-primary"><i class='bx bx-plus'></i>Add Video</a>
    </div>
    <div class="admin-table-wrap">
        <table class="admin-table data-table">
            <thead><tr><th>Thumb</th><th>Title</th><th>Category</th><th>Type</th><th>Published</th><th>Actions</th></tr></thead>
            <tbody>
                @foreach (var v in videos) {
                <tr>
                    <td>
                        <div style="width:80px;height:50px;border-radius:6px;overflow:hidden;background:#0a0f1e">
                            @{ var ytId = v.YouTubeId; var thumb = !string.IsNullOrEmpty(v.ThumbnailUrl)?v.ThumbnailUrl:!string.IsNullOrEmpty(ytId)?$"https://img.youtube.com/vi/{ytId}/default.jpg":null; }
                            @if (thumb != null) { <img src="@thumb" style="width:100%;height:100%;object-fit:cover" loading="lazy" /> }
                        </div>
                    </td>
                    <td style="font-weight:600;max-width:220px">@v.Title</td>
                    <td><span class="status-badge badge-active">@v.CategoryName</span></td>
                    <td style="font-size:.82rem">@v.EmbedType</td>
                    <td><span class="status-badge @(v.IsPublished?"badge-approved":"badge-rejected")">@(v.IsPublished?"Published":"Draft")</span></td>
                    <td>
                        <div class="td-actions">
                            <a href="/admin/videosadmin/edit/@v.VideoId" class="btn-admin-edit"><i class='bx bx-edit'></i>Edit</a>
                            <button class="btn-admin-delete" data-ajax-delete="/admin/videosadmin/delete?id=@v.VideoId" data-label="video '@v.Title'"><i class='bx bx-trash'></i></button>
                        </div>
                    </td>
                </tr>
                }
            </tbody>
        </table>
    </div>
</div>

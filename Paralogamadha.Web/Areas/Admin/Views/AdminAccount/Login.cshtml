@* ============================================================
   Areas/Admin/Views/AdminAccount/Login.cshtml
   ============================================================ *@
@{
    ViewBag.Title = "Admin Login";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex,nofollow" />
    <title>Admin Login — Paralogamadha Basilica</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&family=Playfair+Display:wght@700&display=swap" rel="stylesheet" />
    <link href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        :root { --navy: #1B2A5B; --gold: #C8922A; }
        *, *::before, *::after { box-sizing: border-box; }
        body {
            font-family: 'Inter', sans-serif;
            background: linear-gradient(135deg, #0f1d40 0%, #1B2A5B 60%, #162347 100%);
            min-height: 100vh;
            display: flex; align-items: center; justify-content: center;
            padding: 24px;
        }
        .login-card {
            background: #fff;
            border-radius: 24px;
            padding: 48px 44px;
            width: 100%;
            max-width: 420px;
            box-shadow: 0 32px 80px rgba(0,0,0,0.25);
        }
        .login-logo {
            width: 60px; height: 60px;
            background: linear-gradient(135deg, var(--gold), #e4b040);
            border-radius: 16px;
            display: flex; align-items: center; justify-content: center;
            font-size: 2rem; color: #fff;
            margin: 0 auto 20px;
            box-shadow: 0 6px 20px rgba(200,146,42,0.4);
        }
        .login-title { font-family: 'Playfair Display', serif; font-size: 1.6rem; color: var(--navy); text-align: center; margin-bottom: 4px; }
        .login-sub   { font-size: .82rem; color: #64748b; text-align: center; margin-bottom: 32px; }
        .login-input {
            width: 100%;
            border: 2px solid #e2e8f0;
            border-radius: 10px;
            padding: 12px 16px;
            font-size: .95rem;
            font-family: 'Inter', sans-serif;
            color: #1e293b;
            transition: border-color .2s;
            background: #fff;
        }
        .login-input:focus { outline: none; border-color: var(--navy); box-shadow: 0 0 0 3px rgba(27,42,91,.08); }
        .login-label { display: block; font-size: .82rem; font-weight: 600; color: var(--navy); margin-bottom: 5px; }
        .login-btn {
            width: 100%;
            background: var(--navy);
            color: #fff;
            border: none;
            border-radius: 10px;
            padding: 14px;
            font-size: .95rem;
            font-weight: 700;
            cursor: pointer;
            transition: background .2s, transform .2s;
            margin-top: 8px;
        }
        .login-btn:hover { background: #111d3e; transform: translateY(-1px); }
        .login-error { background: #fef2f2; border: 1px solid #fecaca; border-radius: 8px; padding: 10px 14px; font-size: .85rem; color: #dc2626; margin-bottom: 20px; }
        .input-group-icon { position: relative; }
        .input-group-icon i { position: absolute; left: 14px; top: 50%; transform: translateY(-50%); font-size: 1.1rem; color: #94a3b8; }
        .input-group-icon input { padding-left: 40px; }
        .form-group { margin-bottom: 18px; }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="login-logo">✝</div>
        <div class="login-title">Admin Panel</div>
        <div class="login-sub">Paralogamadha Basilica CMS</div>

        @if (ViewBag.Error != null) {
            <div class="login-error"><i class='bx bx-error-circle me-2'></i>@ViewBag.Error</div>
        }

        @using (Html.BeginForm("Login", "AdminAccount", new { area = "Admin" }, FormMethod.Post)) {
            @Html.AntiForgeryToken()
            <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />

            <div class="form-group">
                <label class="login-label" for="username">Username</label>
                <div class="input-group-icon">
                    <i class='bx bx-user'></i>
                    <input type="text" class="login-input" id="username" name="username"
                           placeholder="Enter your username" autocomplete="username" required autofocus />
                </div>
            </div>

            <div class="form-group">
                <label class="login-label" for="password">Password</label>
                <div class="input-group-icon">
                    <i class='bx bx-lock-alt'></i>
                    <input type="password" class="login-input" id="password" name="password"
                           placeholder="Enter your password" autocomplete="current-password" required />
                </div>
            </div>

            <button type="submit" class="login-btn">
                <i class='bx bx-log-in me-2'></i>Sign In
            </button>
        }

        <div class="mt-4 text-center" style="font-size:.78rem;color:#94a3b8">
            Secure admin access only. Unauthorized access is prohibited.
        </div>
    </div>
</body>
</html>

@* ============================================================
   Areas/Admin/Views/Priests/Index.cshtml
   ============================================================ *@
@{
    ViewBag.Title = "Parish Priests";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    var priests = Model as IEnumerable<Paralogamadha.Core.Models.Priest>;
}
<div class="admin-breadcrumb">
    <a href="/admin/dashboard">Dashboard</a><span class="sep mx-2">/</span>
    <span class="current">Parish Priests</span>
</div>

<div class="admin-panel">
    <div class="panel-header">
        <div class="panel-title"><i class='bx bx-user'></i>Parish Priests</div>
        <a href="/admin/priestadmin/create" class="btn-admin-primary"><i class='bx bx-plus'></i>Add Priest</a>
    </div>
    <div class="admin-table-wrap">
        <table class="admin-table data-table">
            <thead><tr><th>Photo</th><th>Name</th><th>Title</th><th>Tenure</th><th>Status</th><th>Actions</th></tr></thead>
            <tbody>
                @if (priests != null) {
                    foreach (var p in priests) {
                    <tr>
                        <td>
                            <div style="width:44px;height:44px;border-radius:50%;overflow:hidden;background:var(--admin-bg);flex-shrink:0">
                                @if (!string.IsNullOrEmpty(p.PhotoUrl)) {
                                    <img src="@p.PhotoUrl" alt="@p.FullName" style="width:100%;height:100%;object-fit:cover" loading="lazy" />
                                } else {
                                    <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;background:var(--admin-navy);color:#fff;font-weight:700">
                                        @p.FullName.Substring(0,1)
                                    </div>
                                }
                            </div>
                        </td>
                        <td style="font-weight:600">@p.FullName</td>
                        <td style="font-size:.85rem;color:var(--admin-muted)">@(string.IsNullOrEmpty(p.Title)?"—":p.Title)</td>
                        <td style="font-size:.82rem">@(string.IsNullOrEmpty(p.Tenure)?"—":p.Tenure)</td>
                        <td>
                            @if (p.IsCurrent) {
                                <span class="status-badge badge-approved">Current</span>
                            } else {
                                <span class="status-badge badge-pending">Former</span>
                            }
                        </td>
                        <td>
                            <div class="td-actions">
                                <a href="/admin/priestadmin/edit/@p.PriestId" class="btn-admin-edit"><i class='bx bx-edit'></i>Edit</a>
                                <button class="btn-admin-delete"
                                        data-ajax-delete="/admin/priestadmin/delete?id=@p.PriestId"
                                        data-label="@p.FullName's profile"><i class='bx bx-trash'></i></button>
                            </div>
                        </td>
                    </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

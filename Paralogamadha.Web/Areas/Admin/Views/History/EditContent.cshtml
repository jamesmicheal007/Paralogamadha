@* ============================================================
   Areas/Admin/Views/History/EditContent.cshtml
   ============================================================ *@
@using Paralogamadha.Core.Models
@{
    ViewBag.Title = (Model as HistoryContent)?.ContentId > 0 ? "Edit History Section" : "Add History Section";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    var h     = Model as HistoryContent ?? new HistoryContent();
    var langs = ViewBag.Languages as IEnumerable<Language>;
}
<div class="admin-breadcrumb">
    <a href="/admin/dashboard">Dashboard</a><span class="sep mx-2">/</span>
    <a href="/admin/historyadmin">History</a><span class="sep mx-2">/</span>
    <span class="current">@ViewBag.Title</span>
</div>

<div class="row g-4">
    <div class="col-lg-9">
        <div class="admin-panel">
            <div class="panel-header"><div class="panel-title"><i class='bx bx-book'></i>@ViewBag.Title</div></div>
            <div class="panel-body">
                @using (Html.BeginForm("SaveContent", "HistoryAdmin", new { area = "Admin" }, FormMethod.Post)) {
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="ContentId" value="@h.ContentId" />

                    <div class="row g-3">
                        <div class="col-md-8 form-group">
                            <label class="admin-label">Section Title <span class="required">*</span></label>
                            <input type="text" class="admin-input" name="Title" value="@h.Title" required
                                   placeholder="e.g. Origins of the Parish" />
                        </div>
                        <div class="col-md-2 form-group">
                            <label class="admin-label">Language</label>
                            <select class="admin-select" name="LanguageId">
                                @if (langs != null) {
                                    foreach (var l in langs) {
                                        <option value="@l.LanguageId" @(h.LanguageId==l.LanguageId?"selected":"")>@l.DisplayName</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-md-2 form-group">
                            <label class="admin-label">Sort Order</label>
                            <input type="number" class="admin-input" name="SortOrder" value="@h.SortOrder" min="0" />
                        </div>
                        <div class="col-12 form-group">
                            <label class="admin-label">Content (Rich Text)</label>
                            <input type="hidden" name="BodyHtml" id="BodyHtmlHidden" value="@h.BodyHtml" />
                            <div class="admin-quill-wrap">
                                <div class="quill-editor" data-target="BodyHtmlHidden" style="min-height:300px"></div>
                            </div>
                            <div class="form-hint">HTML is sanitized on save. You can include headings, images, blockquotes and links.</div>
                        </div>
                    </div>
                    <div class="d-flex gap-3 mt-4">
                        <button type="submit" class="btn-admin-primary"><i class='bx bx-save'></i>Save Section</button>
                        <a href="/admin/historyadmin" class="btn btn-secondary">Cancel</a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>


@* ============================================================
   Areas/Admin/Views/History/EditTimeline.cshtml
   ============================================================ *@
@*
@using Paralogamadha.Core.Models
@{
    ViewBag.Title = (Model as HistoryTimeline)?.TimelineId > 0 ? "Edit Milestone" : "Add Milestone";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    var t     = Model as HistoryTimeline ?? new HistoryTimeline();
    var langs = ViewBag.Languages as IEnumerable<Language>;
}
<div class="admin-breadcrumb"><a href="/admin/dashboard">Dashboard</a><span class="sep mx-2">/</span><a href="/admin/historyadmin">History</a><span class="sep mx-2">/</span><span class="current">@ViewBag.Title</span></div>
<div class="row justify-content-center">
  <div class="col-lg-7">
    <div class="admin-panel">
      <div class="panel-header"><div class="panel-title"><i class='bx bx-time-five'></i>@ViewBag.Title</div></div>
      <div class="panel-body">
        @using (Html.BeginForm("SaveTimeline", "HistoryAdmin", new { area = "Admin" }, FormMethod.Post, new { enctype = "multipart/form-data" })) {
          @Html.AntiForgeryToken()
          <input type="hidden" name="TimelineId" value="@t.TimelineId" />
          <div class="row g-3">
            <div class="col-md-3 form-group"><label class="admin-label">Year <span class="required">*</span></label><input type="number" class="admin-input" name="Year" value="@t.Year" required min="1000" max="2100" /></div>
            <div class="col-md-7 form-group"><label class="admin-label">Title <span class="required">*</span></label><input type="text" class="admin-input" name="Title" value="@t.Title" required placeholder="e.g. Basilica Elevated by Vatican" /></div>
            <div class="col-md-2 form-group"><label class="admin-label">Language</label><select class="admin-select" name="LanguageId">@foreach(var l in langs??Enumerable.Empty<Language>()){<option value="@l.LanguageId" @(t.LanguageId==l.LanguageId?"selected":"")>@l.DisplayName</option>}</select></div>
            <div class="col-12 form-group"><label class="admin-label">Description</label><textarea class="admin-input" name="Description" rows="4">@t.Description</textarea></div>
            <div class="col-12 form-group">
              <label class="admin-label">Image</label>
              <div class="img-upload-wrap"><input type="file" name="Image" accept="image/jpeg,image/png,image/webp" /><div class="img-upload-icon"><i class='bx bx-image'></i></div><div class="img-upload-text"><strong>Upload image</strong></div><img class="img-preview" src="@t.ImageUrl" alt="" @(!string.IsNullOrEmpty(t.ImageUrl)?"style='display:block'":"") /></div>
              @if(t.TimelineId>0 && !string.IsNullOrEmpty(t.ImageUrl)){<input type="hidden" name="ImageUrl" value="@t.ImageUrl" />}
            </div>
          </div>
          <div class="d-flex gap-3 mt-4"><button type="submit" class="btn-admin-primary"><i class='bx bx-save'></i>Save</button><a href="/admin/historyadmin" class="btn btn-secondary">Cancel</a></div>
        }
      </div>
    </div>
  </div>
</div>
*@

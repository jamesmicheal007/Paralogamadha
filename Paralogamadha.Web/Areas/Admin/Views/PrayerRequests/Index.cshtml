@* ============================================================
   Areas/Admin/Views/PrayerRequests/Index.cshtml
   ============================================================ *@
@{
    ViewBag.Title = "Prayer Requests";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    var requests = Model as IEnumerable<Paralogamadha.Core.Models.PrayerRequest>;
    var antiForgery = Html.AntiForgeryToken().ToString();
}
<div class="admin-breadcrumb">
    <a href="/admin/dashboard">Dashboard</a><span class="sep mx-2">/</span>
    <span class="current">Prayer Requests</span>
</div>

<div class="admin-panel">
    <div class="panel-header">
        <div class="panel-title"><i class='bx bx-heart'></i>Prayer Requests</div>
        <div class="d-flex gap-2">
            <a href="?status=" class="filter-chip @(Context.Request.QueryString["status"]==""?"active":"")">All</a>
            <a href="?status=1"  class="filter-chip @(Context.Request.QueryString["status"]=="1"?"active":"")">Pending</a>
            <a href="?status=2"  class="filter-chip @(Context.Request.QueryString["status"]=="2"?"active":"")">Approved</a>
            <a href="?status=3"  class="filter-chip @(Context.Request.QueryString["status"]=="3"?"active":"")">Rejected</a>
        </div>
    </div>
    <div class="admin-table-wrap">
        <table class="admin-table data-table">
            <thead>
                <tr>
                    <th>ID</th><th>Name</th><th>Category</th><th>Request</th>
                    <th>Date</th><th>Status</th><th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (requests != null) {
                    foreach (var r in requests) {
                    <tr>
                        <td>#@r.RequestId</td>
                        <td>
                            <div style="font-weight:600">@(r.IsAnonymous ? "Anonymous" : r.FullName)</div>
                            @if (!string.IsNullOrEmpty(r.Email) && !r.IsAnonymous) {
                                <div style="font-size:.78rem;color:var(--admin-muted)">@r.Email</div>
                            }
                        </td>
                        <td><span class="status-badge badge-active">@r.PrayerCategory</span></td>
                        <td style="max-width:260px">
                            <div style="font-size:.85rem;overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical">@r.PrayerText</div>
                        </td>
                        <td style="white-space:nowrap;font-size:.82rem">@r.CreatedAt.ToString("dd MMM yyyy")</td>
                        <td><span class="status-badge @r.StatusBadgeClass.Replace("badge ","badge-").Replace("bg-","")">@r.StatusLabel</span></td>
                        <td>
                            <div class="td-actions">
                                <button class="btn-admin-view" data-bs-toggle="modal" data-bs-target="#prayerModal_@r.RequestId">
                                    <i class='bx bx-show'></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                    @* Review Modal *@
                    <div class="modal fade" id="prayerModal_@r.RequestId" tabindex="-1">
                        <div class="modal-dialog modal-dialog-centered">
                            <div class="modal-content" style="border-radius:16px;border:none">
                                <div class="modal-header" style="border:none;padding:24px 28px 0">
                                    <h5 class="modal-title text-navy">Prayer Request #@r.RequestId</h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                </div>
                                <div class="modal-body px-4">
                                    @Html.Raw(antiForgery)
                                    <div class="mb-3">
                                        <div class="admin-label">Submitted by</div>
                                        <div>@(r.IsAnonymous ? "Anonymous" : r.FullName)
                                        @if (!r.IsAnonymous && !string.IsNullOrEmpty(r.Email)) {
                                            <span class="ms-2 text-muted" style="font-size:.85rem">@r.Email</span>
                                        }</div>
                                    </div>
                                    <div class="mb-3">
                                        <div class="admin-label">Category</div>
                                        <span class="status-badge badge-active">@r.PrayerCategory</span>
                                    </div>
                                    <div class="mb-3">
                                        <div class="admin-label">Prayer Request</div>
                                        <div style="background:#fffdf6;border:1px solid #f0e8cc;border-radius:8px;padding:14px;font-size:.9rem;line-height:1.7">@r.PrayerText</div>
                                    </div>
                                    <div class="mb-3">
                                        <label class="admin-label" for="adminNotes_@r.RequestId">Admin Notes</label>
                                        <textarea class="admin-input" id="adminNotes_@r.RequestId" rows="2"
                                                  placeholder="Optional notes…">@r.AdminNotes</textarea>
                                    </div>
                                </div>
                                <div class="modal-footer" style="border:none;padding:0 28px 24px;gap:8px">
                                    <button class="btn-admin-approve"
                                            data-ajax-review="/admin/prayerrequestadmin/review"
                                            data-status-id="2" data-entity-id="@r.RequestId">
                                        <i class='bx bx-check'></i>Approve
                                    </button>
                                    <button class="btn-admin-reject"
                                            data-ajax-review="/admin/prayerrequestadmin/review"
                                            data-status-id="3" data-entity-id="@r.RequestId">
                                        <i class='bx bx-x'></i>Reject
                                    </button>
                                    <button class="ms-auto btn btn-sm btn-secondary" data-bs-dismiss="modal">Close</button>
                                </div>
                            </div>
                        </div>
                    </div>
                    }
                }
            </tbody>
        </table>
    </div>
</div>


@* ============================================================
   Areas/Admin/Views/Testimonials/Index.cshtml
   ============================================================ *@
@*
@{
    ViewBag.Title = "Testimonials";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    var testimonials = Model as IEnumerable<Paralogamadha.Core.Models.Testimonial>;
}
<div class="admin-breadcrumb">
    <a href="/admin/dashboard">Dashboard</a><span class="sep mx-2">/</span>
    <span class="current">Testimonials</span>
</div>

<div class="admin-panel">
    <div class="panel-header">
        <div class="panel-title"><i class='bx bx-star'></i>Testimonials</div>
    </div>
    <div class="admin-table-wrap">
        <table class="admin-table data-table">
            <thead><tr><th>ID</th><th>Author</th><th>Rating</th><th>Text</th><th>Status</th><th>Featured</th><th>Actions</th></tr></thead>
            <tbody>
                @foreach (var t in testimonials ?? Enumerable.Empty<Paralogamadha.Core.Models.Testimonial>()) {
                <tr>
                    <td>#@t.TestimonialId</td>
                    <td><div style="font-weight:600">@t.AuthorName</div><div style="font-size:.78rem;color:var(--admin-muted)">@t.AuthorLocation</div></td>
                    <td>@for(int i=1;i<=5;i++){<i class="bx @(i<=t.Rating?"bxs-star text-warning":"bx-star text-muted")" style="font-size:.9rem"></i>}</td>
                    <td style="max-width:260px;font-size:.85rem">@(t.TestimonialText.Length>80?t.TestimonialText.Substring(0,80)+"…":t.TestimonialText)</td>
                    <td><span class="status-badge @(t.StatusId==2?"badge-approved":t.StatusId==3?"badge-rejected":"badge-pending")">@(t.StatusId==2?"Approved":t.StatusId==3?"Rejected":"Pending")</span></td>
                    <td>
                        <div class="form-check form-switch mb-0">
                            <input type="checkbox" class="form-check-input" role="switch"
                                   @(t.FeaturedOnHome?"checked":"")
                                   data-ajax-toggle="/admin/testimonialadmin/togglefeatured"
                                   data-field="featured" data-id="@t.TestimonialId" />
                        </div>
                    </td>
                    <td>
                        <div class="td-actions">
                            <button class="btn-admin-approve" data-ajax-review="/admin/testimonialadmin/review" data-status-id="2" data-entity-id="@t.TestimonialId"><i class='bx bx-check'></i></button>
                            <button class="btn-admin-reject" data-ajax-review="/admin/testimonialadmin/review" data-status-id="3" data-entity-id="@t.TestimonialId"><i class='bx bx-x'></i></button>
                            <button class="btn-admin-delete" data-ajax-delete="/admin/testimonialadmin/delete?id=@t.TestimonialId" data-label="testimonial #@t.TestimonialId"><i class='bx bx-trash'></i></button>
                        </div>
                    </td>
                </tr>
                }
            </tbody>
        </table>
    </div>
</div>
*@
